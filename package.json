{
  "name": "tcms",
  "version": "1.0.0",
  "description": "Standalone backend-first Test Case Management System (TCMS) for small QA teams.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "ci:typecheck": "npm run typecheck",
    "ci:test": "npm test",
    "ci:migration:fresh": "tsx scripts/ci/check-migrations-fresh.ts",
    "ci:migration:upgrade": "tsx scripts/ci/check-migrations-upgrade.ts",
    "ci:schema:check": "tsx scripts/ci/check-schema-contract.ts",
    "ci:schema:update": "tsx scripts/ci/update-schema-snapshot.ts",
    "ci:security:nonblocking": "tsx scripts/ci/check-security-nonblocking.ts",
    "ci:hardening": "npm run ci:typecheck && npm run ci:test && npm run ci:migration:fresh && npm run ci:migration:upgrade && npm run ci:schema:check && npm run ci:security:nonblocking"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
