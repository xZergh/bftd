{
  "name": "tcms",
  "version": "1.0.0",
  "description": "Standalone backend-first Test Case Management System (TCMS) for small QA teams.",
  "main": "dist/server.js",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "npm run dev -w tcms-web",
    "start:e2e-api": "cross-env DB_PATH=./data/e2e-playwright.sqlite PORT=4000 tsx src/server.ts",
    "e2e:web": "npm run e2e -w tcms-web",
    "ci:e2e:web": "cross-env CI=true npm run e2e:ci -w tcms-web",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "ci:typecheck": "npm run typecheck",
    "ci:lint": "eslint .",
    "ci:architecture:boundaries": "tsx scripts/ci/check-architecture-boundaries.ts",
    "ci:test": "npm test",
    "ci:migration:fresh": "tsx scripts/ci/check-migrations-fresh.ts",
    "ci:migration:upgrade": "tsx scripts/ci/check-migrations-upgrade.ts",
    "ci:schema:check": "tsx scripts/ci/check-schema-contract.ts",
    "ci:schema:indexes": "tsx scripts/ci/check-schema-indexes.ts",
    "ci:schema:update": "tsx scripts/ci/update-schema-snapshot.ts",
    "ci:security:nonblocking": "tsx scripts/ci/check-security-nonblocking.ts",
    "allure:generate": "node scripts/allure-generate.cjs",
    "ci:mutation": "stryker run",
    "ci:hardening": "npm run ci:typecheck && npm run ci:lint && npm run ci:architecture:boundaries && npm run ci:test && npm run ci:migration:fresh && npm run ci:migration:upgrade && npm run ci:schema:check && npm run ci:schema:indexes && npm run ci:security:nonblocking"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.2",
    "graphql": "^16.13.2",
    "graphql-yoga": "^5.21.0",
    "swagger-ui-dist": "^5.32.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.3",
    "allure-commandline": "^2.38.1",
    "allure-vitest": "^3.7.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3",
    "cross-env": "^7.0.3"
  }
}
